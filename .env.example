# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# OpenAI API Key - for AI features (ask, search, generate)
OPENAI_API_KEY=your_openai_api_key

# Optional: Override LeetCode API base (default uses leetcode-api-pied.vercel.app)
# LEETCODE_API_BASE=https://leetcode-api-pied.vercel.app

# Optional: AI model for the ReAct agent (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# Optional: Max tool-calling iterations for the agent (default: 8)
# AGENT_MAX_ITERATIONS=8

# Optional: Default daily notification time in UTC (default: 08:00)
# DAILY_NOTIFY_HOUR=8
# DAILY_NOTIFY_MINUTE=0
